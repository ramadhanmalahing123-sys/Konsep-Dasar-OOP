# 1) Buat class Kendaraan dengan class attribute
class Kendaraan:
    # Class Attribute: Dimiliki oleh Class, dibagi oleh semua objek
    bahan_bakar = "Bensin/Diesel"

    # 2) Gunakan constructor untuk inisialisasi merk, warna, dan tahun
    def __init__(self, merk, warna, tahun):
        # Instance Attributes: Unik untuk setiap objek
        self.merk = merk
        self.warna = warna
        self.tahun = tahun

    def info_kendaraan(self):
        return (
            f"Kendaraan: {self.merk} ({self.tahun}), Warna: {self.warna}. "
            f"Bahan Bakar Utama: {Kendaraan.bahan_bakar}"
        )

# --- Instansiasi Object ---
mobil1 = Kendaraan("Toyota", "Putih", 2024)
motor1 = Kendaraan("Honda", "Merah", 2023)

print("--- Hasil Instance Attributes (Unik per Objek) ---")
# Akses Instance Attribute: nilai berbeda untuk setiap objek
print(f"Merk mobil1: {mobil1.merk}")
print(f"Warna motor1: {motor1.warna}")

print("\n--- Hasil Class Attribute (Dibagi Semua Objek) ---")
# 3) Demonstrasikan perbedaan akses instance attribute dan class attribute
# Cara 1: Mengakses Class Attribute melalui Nama Class (Paling Disarankan)
print(f"Bahan Bakar Umum (via Class): {Kendaraan.bahan_bakar}")

# Cara 2: Mengakses Class Attribute melalui Nama Objek (Berfungsi, tapi kurang ideal)
print(f"Bahan Bakar mobil1 (via Objek): {mobil1.bahan_bakar}")