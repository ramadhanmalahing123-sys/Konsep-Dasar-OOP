class Mahasiswa:
    # 2b. Class attribute
    universitas = "STITEK Bontang"

    # 3a. Constructor (__init__)
    def __init__(self, nama, nim, jurusan, ipk=0.0):
        # 2a. Instance attributes
        self.nama = nama
        self.nim = nim
        self.jurusan = jurusan
        self.ipk = ipk

    # 3b. Method perkenalan_diri()
    def perkenalan_diri(self):
        return (f"Halo, saya {self.nama}, NIM {self.nim}, dari Jurusan {self.jurusan}. "
                f"Saya adalah mahasiswa di {Mahasiswa.universitas}.")

    # 3c. Method update_ipk()
    def update_ipk(self, ipk_baru):
        if 0.0 <= ipk_baru <= 4.0:
            self.ipk = ipk_baru
            return f"IPK {self.nama} berhasil diperbarui menjadi {self.ipk}."
        else:
            return "Nilai IPK tidak valid (harus antara 0.0 dan 4.0)."

    # 3d. Method predikat_kelulusan()
    def predikat_kelulusan(self):
        ipk = self.ipk
        if ipk >= 3.5:
            predikat = "Cum Laude"
        elif ipk >= 3.0:
            predikat = "Sangat Memuaskan"
        elif ipk >= 2.5:
            predikat = "Memuaskan"
        elif ipk >= 2.0:
            predikat = "Lulus"
        else:
            predikat = "Belum Memenuhi Syarat Kelulusan"
            
        return f"Predikat kelulusan untuk IPK {ipk}: {predikat}"

# --- 4. Instansiasi dan Demonstrasi ---
print("--- 4a. Membuat 3 Objek Mahasiswa ---")
mhs1 = Mahasiswa("Ahmad Yani", "TI001", "Teknik Informatika")
mhs2 = Mahasiswa("Bunga Lestari", "SI002", "Sistem Informasi", ipk=3.65)
mhs3 = Mahasiswa("Cahyo Widodo", "TE003", "Teknik Elektro", ipk=2.80)

print("\n--- 4b. Demonstrasi Method perkenalan_diri() ---")
print(mhs1.perkenalan_diri())
print(mhs2.perkenalan_diri())
# Mengakses Class Attribute secara langsung
print(f"Nama Universitas: {Mahasiswa.universitas}")

print("\n--- 4b. Demonstrasi Method update_ipk() ---")
# mhs1 memiliki IPK awal 0.0, mari kita update
print(mhs1.update_ipk(3.15))
# Coba update IPK dengan nilai yang tidak valid
print(mhs3.update_ipk(4.5))

print("\n--- 4b. Demonstrasi Method predikat_kelulusan() ---")
print(f"{mhs1.nama}: {mhs1.predikat_kelulusan()}") # IPK 3.15 -> Sangat Memuaskan
print(f"{mhs2.nama}: {mhs2.predikat_kelulusan()}") # IPK 3.65 -> Cum Laude
print(f"{mhs3.nama}: {mhs3.predikat_kelulusan()}") # IPK 2.80 -> Memuaskan